<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="50dp"
    android:paddingRight="16dp"
    android:paddingLeft="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvExamTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Exam Questions"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:textColor="#000000"/>

    <EditText
        android:id="@+id/etQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="اكتب نص السؤال هنا..."
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:gravity="top"
        android:lines="3"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الاختيارات وتحديد الإجابة الصحيحة:"
        android:textColor="@color/black"
        android:layout_marginTop="15dp"
        android:textStyle="bold"/>

    <RadioGroup
        android:id="@+id/rgOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


            <RadioButton android:id="@+id/rbA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A" android:textColor="@color/black"/>
            <EditText android:id="@+id/etOpA" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الاختيار الأول" android:textColorHint="@color/black" android:textColor="@color/black"/>



            <RadioButton android:id="@+id/rbB" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B" android:textColor="@color/black"/>
            <EditText android:id="@+id/etOpB" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الاختيار الثاني" android:textColorHint="@color/black" android:textColor="@color/black"/>



            <RadioButton android:id="@+id/rbC" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:textColor="@color/black"/>
            <EditText android:id="@+id/etOpC" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الاختيار الثالث" android:textColorHint="@color/black" android:textColor="@color/black"/>



            <RadioButton android:id="@+id/rbD" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D" android:textColor="@color/black"/>
            <EditText android:id="@+id/etOpD" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="الاختيار الرابع" android:textColorHint="@color/black" android:textColor="@color/black"/>

    </RadioGroup>

    <Button
        android:id="@+id/btnAddNextQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save and Go For Next Question"
        android:layout_marginTop="20dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnFinishExam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finish and Save Exam"
        android:layout_marginTop="10dp"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"/>

</LinearLayout>